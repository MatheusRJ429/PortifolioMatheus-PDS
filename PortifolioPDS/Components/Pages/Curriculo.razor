@page "/Curriculo"

<PageTitle>Meu Currículo</PageTitle>

<section class="pagina-curriculo">

    <div class="perfil-topo">

        <div class="foto-perfil">
            MR
        </div>

        <h1>Matheus Rodrigues Júlio</h1>

        <p>
            Desenvolvedor em aprendizado • Tecnologia • Design • Sistemas
        </p>

    </div>

    <div class="linha"></div>

    <div class="cards-curriculo">

        <div class="card">

            <span class="numero">01</span>

            <h2>Sobre Mim</h2>

            <p>
                Sou apaixonado por tecnologia e desenvolvimento.
                Gosto de criar projetos modernos, aprender novas ferramentas
                e evoluir constantemente minhas habilidades.
            </p>

        </div>

        <div class="card">

            <span class="numero">02</span>

            <h2>Habilidades</h2>

            <div class="habilidades">

                <span>HTML</span>
                <span>CSS</span>
                <span>C#</span>
                <span>Blazor</span>
                <span>Figma</span>
                <span>Banco de Dados</span>

            </div>

        </div>

        <div class="card">

            <span class="numero">03</span>

            <h2>Objetivos</h2>

            <p>
                Meu objetivo é crescer profissionalmente na área
                da tecnologia e participar de projetos cada vez maiores.
            </p>

        </div>

    </div>

    <div class="rodape-curriculo">

        <a href="/" class="botao-home">
            Voltar para Home
        </a>

    </div>

</section>